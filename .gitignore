# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual envs
venv/
.venv/
env/

# Secrets
*.env
*.env.*
!*.env.example
config/api_keys.env
config/*.bak

