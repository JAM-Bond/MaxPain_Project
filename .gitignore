scripts/orats/config.py
!scripts/orats/config.py.example

# Data / DB
*.db
*.db-journal
*.sqlite
*.sqlite3
data/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Streamlit
.streamlit/secrets.toml

# launchd — only the template is tracked
dashboard/launchd/*.plist
!dashboard/launchd/*.plist.template
